{{- /* Reminder banner for interactive shells */ -}}
{{- /* Delegates to the Bun-based `reminder banner` command for correct OSC 8 output */ -}}
{{- if eq .shell "fish" }}
# Display reminder banner (clickable links in supported terminals)
if test -d ~/reminders; and command -q reminder.ts
    reminder.ts banner
end
{{- else if eq .shell "bash" }}
# Display reminder banner (clickable links in supported terminals)
if [ -d ~/reminders ] && command -v reminder.ts &>/dev/null; then
    reminder.ts banner
fi
{{- end }}
