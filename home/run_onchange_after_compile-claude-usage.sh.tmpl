{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
# hash: {{ include "dot_local/bin/claude-usage.ts" | sha256sum }}
set -euo pipefail

SRC="{{ .chezmoi.homeDir }}/.local/bin/claude-usage.ts"
OUT="{{ .chezmoi.homeDir }}/.local/bin/claude-usage"

if ! command -v bun &>/dev/null; then
  echo "[compile-claude-usage] bun not found, skipping compilation"
  exit 0
fi

echo "[compile-claude-usage] Compiling claude-usage.ts → binary"
bun build --compile "$SRC" --outfile "$OUT"
chmod +x "$OUT"
echo "[compile-claude-usage] Done"
{{ end -}}
