{
	"name": "commit",
	"version": "0.1.0",
	"description": "Interactive AI-powered commit message generator using Claude Agent SDK",
	"module": "src/cli.ts",
	"type": "module",
	"private": true,
	"bin": {
		"commit": "src/cli.ts"
	},
	"scripts": {
		"start": "bun run src/cli.ts",
		"check": "bun run --bun tsc --noEmit && bunx biome check src/"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"typescript": "^5"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.81",
		"@clack/core": "^0.4.2",
		"@clack/prompts": "^0.10.0",
		"ajv": "^8.18.0",
		"citty": "^0.1.6",
		"picocolors": "^1.1.1"
	}
}
